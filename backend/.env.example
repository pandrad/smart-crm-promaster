# Azure AD app registration
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# The shared mailbox / group inbox to monitor
INBOX_USER_ID=info@promaster.co

# Graph API webhook — must be a public HTTPS URL (use ngrok for local testing)
# e.g. https://abc123.ngrok-free.app
WEBHOOK_BASE_URL=https://your-ngrok-url-here

# Shared secret for validating incoming Graph API notifications
WEBHOOK_SECRET=change-me-to-a-random-string
